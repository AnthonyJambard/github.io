# OS-generated files
.DS_Store # Mac OS
Thumbs.db # Windows

# Editor/IDE files
.idea/ # JetBrains IDEs
*.iml # JetBrains IDEs
.vscode/ # VS Code (often only workspace settings are ignored)

# Build artifacts/temporary files (if applicable to your workflow)
/build/
/dist/
.tmp/
*.log

# Dependencies (if you are using package managers in a web project)
node_modules/
bower_components/
